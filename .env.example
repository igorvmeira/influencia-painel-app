# ===== FIREBASE ADMIN (servidor) — escolha UMA das duas opções =====

# OPÇÃO A (recomendada, à prova de erro de chave):
# Pegue o JSON da conta de serviço (Firebase > Configurações > Contas de serviço >
# Gerar nova chave privada) e converta o arquivo inteiro para base64.
# Cole o resultado numa linha só aqui:
FIREBASE_SERVICE_ACCOUNT_BASE64=

# OPÇÃO B (três variáveis separadas):
# FIREBASE_PROJECT_ID=seu-projeto
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@seu-projeto.iam.gserviceaccount.com
# IMPORTANTE: no .env.local, a chave PRECISA estar entre aspas e com \n literais.
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ===== FIREBASE WEB (cliente) — OBRIGATÓRIAS =====
# Config pública do Firebase (Configurações do projeto > Seus apps > App da Web).
# NÃO são segredo (vão para o navegador), mas SEM elas o login não funciona —
# e todas as telas são protegidas por login.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ===== META MARKETING API (servidor, SEGREDO) =====
META_ACCESS_TOKEN=
META_API_VERSION=v21.0

# ===== SEGURANÇA DAS ROTAS INTERNAS (servidor, SEGREDO) — OBRIGATÓRIA =====
# String aleatória e forte. Protege /api/sync-meta, /api/import-contas,
# /api/import-orientacoes e /api/diagnostico-contas (via "Authorization: Bearer
# <CRON_SECRET>" ou ?key=<CRON_SECRET>).
# ATENÇÃO: a verificação FALHA FECHADO — sem esta variável, essas rotas respondem
# 500 e não executam nada (antes ficavam abertas). O cron do GitHub Actions manda
# esta mesma chave.
CRON_SECRET=

# ===== GOOGLE AGENDA (servidor, SEGREDO) — necessário para a tela /reunioes =====
# ID do calendário da agência (Agenda > Configurações do calendário > ID).
# O calendário precisa estar COMPARTILHADO com o e-mail da conta de serviço abaixo.
GOOGLE_CALENDAR_ID=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
# Mesma regra da chave do Firebase: entre aspas e com \n literais.
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nMIIE...\n-----END PRIVATE KEY-----\n"

# ===== MÓDULO DE IA (opcional, premium) — DESLIGADO por padrão =====
# Sem ANTHROPIC_API_KEY a rota /api/ia não chama a Claude (custo zero).
ANTHROPIC_API_KEY=
# Liga a interface do chat no painel. Só aparece com o valor exato "true".
NEXT_PUBLIC_IA_ATIVA=false
